# Local run configuration template. Copy to .env (gitignored) and fill in.
# run_pipeline.ps1 loads this automatically; on Linux/WSL source it with:
#     set -a; . ./.env; set +a
# Plain KEY=value and bash-style `export KEY='value'` lines both work.

# --- Cloud / Macro vision model (OpenRouter, Gemini, Anthropic, OpenAI, Kimi) ---
MACRO_API_KEY=your_api_key_here
MACRO_BASE_URL=https://openrouter.ai/api/v1
MACRO_MODEL=anthropic/claude-sonnet-4-6

# --- Local / Micro code model (LM Studio, Ollama, llama.cpp, vLLM, MLX) ---
MICRO_BASE_URL=http://localhost:1234/v1
MICRO_MODEL=qwen2.5-coder

# --- Optional knobs ---
# Disable proactive per-frame vision polling (recommended when the macro tier
# shares one local endpoint with the micro tier).
#SONIC_PROACTIVE_VISION=0
# Disable agentic failure diagnosis (the vision model interactively replaying
# failures with emulator tools before mutating). On by default; it requires a
# macro model whose endpoint supports OpenAI tool calling.
#SONIC_AGENTIC_DIAGNOSIS=0
# Force the emulator backend: auto | stable | legacy
#SONIC_RETRO_BACKEND=auto
# ROM used by run_pipeline.ps1 to seed the backend data dir on first run.
#SONIC_ROM_SOURCE=C:\path\to\SonicTheHedgehog.bin
